def word_color(word):
    return WORD_COLORS.get(word, emotion_colors.get(
        emotion_map.get(word, "neutral"), "#888780"
    ))

# -------------------------
# load & prep data
# -------------------------
df = pd.read_csv(TREND_CSV)
df["album_year"] = df["album_year"].astype(str)
df = df.sort_values("album_year").reset_index(drop=True)

words = [c for c in df.columns if c != "album_year"]
years = df["album_year"].tolist()
n_albums = len(years)

# Convert raw counts to percentage share per album
# Each word's value = its count / sum of all top-15 words that album * 100
raw_values = df[words].values.astype(float)
row_totals = raw_values.sum(axis=1, keepdims=True)
row_totals[row_totals == 0] = 1  # avoid divide by zero
values = raw_values / row_totals * 100  # shape (n_albums, n_words)

# Global x max — fixed across all frames so axis never rescales
GLOBAL_X_MAX = 38.0  # bars fill ~90% of axis, stopping short of right labels

# -------------------------
# interpolate between albums
# for smooth animation
# -------------------------
# Total frames: (n_albums - 1) * FRAMES_PER_ALBUM + 1
def get_frame_data(frame):
    """
    Returns (word_vals dict, album_idx float, interp_t float)
    for a given frame number.
    """
    total_segments = n_albums - 1
    if total_segments == 0:
        return dict(zip(words, values[0])), 0, 0.0

    segment = min(frame // FRAMES_PER_ALBUM, total_segments - 1)
    t = (frame % FRAMES_PER_ALBUM) / FRAMES_PER_ALBUM

    v_start = values[segment]
    v_end   = values[min(segment + 1, n_albums - 1)]

    # Ease in-out interpolation
    t_ease = t * t * (3 - 2 * t)
    v_interp = v_start + (v_end - v_start) * t_ease

    return dict(zip(words, v_interp)), segment, t_ease

def get_year_label(frame):
    total_segments = n_albums - 1
    if total_segments == 0:
        return years[0]
    segment = min(frame // FRAMES_PER_ALBUM, total_segments - 1)
    t = (frame % FRAMES_PER_ALBUM) / FRAMES_PER_ALBUM
    # interpolate year numerically for display
    y0 = int(years[segment])
    y1 = int(years[min(segment + 1, n_albums - 1)])
    y_interp = y0 + (y1 - y0) * t
    return f"{int(round(y_interp))}"

def get_album_label(frame):
    total_segments = n_albums - 1
    segment = min(frame // FRAMES_PER_ALBUM, total_segments - 1)
    year = years[segment]
    title = ALBUM_TITLES.get(year, "")
    return f"{year}  —  {title}" if title else year

# -------------------------
# figure setup
# -------------------------
fig, ax = plt.subplots(figsize=(12, 7), dpi=120)
fig.patch.set_facecolor("#0e0c0a")
ax.set_facecolor("#0e0c0a")

for spine in ax.spines.values():
    spine.set_visible(False)

ax.tick_params(left=False, bottom=True, colors="#888780", labelsize=11)
ax.xaxis.set_tick_params(color="#888780")
ax.yaxis.set_tick_params(left=False)

# Year label — large, top right
year_text = ax.text(
    0.98, 0.95, "",
