    ha="left",
)

total_frames = (n_albums - 1) * FRAMES_PER_ALBUM + 1

# -------------------------
# animation function
# -------------------------
def animate(frame):
    ax.clear()
    # Clear any fig-level text from previous frame
    for txt in fig.texts[1:]:  # keep index 0 which is the chart title
        txt.remove()
    ax.set_facecolor("#0e0c0a")
    for spine in ax.spines.values():
        spine.set_visible(False)

    word_vals, segment, t = get_frame_data(frame)

    # Sort and take top N
    sorted_words = sorted(word_vals.items(), key=lambda x: x[1])
    top = sorted_words[-TOP_N_BARS:]
    top_words  = [w for w, _ in top]
    top_vals   = [v for _, v in top]
    top_colors = [word_color(w) for w in top_words]

    # Draw bars
    bars = ax.barh(
        top_words, top_vals,
        color=top_colors,
        height=BAR_HEIGHT,
        edgecolor="none",
    )

    # Value labels at end of each bar
    x_max = max(top_vals) if top_vals else 1
    for bar, val, word in zip(bars, top_vals, top_words):
        ax.text(
            val + GLOBAL_X_MAX * 0.01,
            bar.get_y() + bar.get_height() / 2,
            f"{val:.1f}%",
            va="center", ha="left",
            fontsize=11, color="#e8e0d5",
            fontfamily="serif",
        )

    # Axis styling — fixed x range across all frames
    ax.set_xlim(0, GLOBAL_X_MAX)
    ax.set_ylim(-0.5, TOP_N_BARS - 0.5)
    ax.tick_params(colors="#888780", labelsize=11)
    ax.xaxis.set_major_formatter(ticker.FuncFormatter(lambda x, _: f"{int(x)}"))
    for spine in ax.spines.values():
        spine.set_visible(False)
    ax.tick_params(left=False)

    # Word labels on y axis with emotion colors
    ax.set_yticks(range(len(top_words)))
    ax.set_yticklabels(top_words, fontsize=13, fontfamily="serif")
    for label, word in zip(ax.get_yticklabels(), top_words):
        label.set_color(word_color(word))

    # Year — placed in figure coords so it's always in the right margin
    fig.text(
        0.97, 0.48, get_year_label(frame),
        ha="right", va="top",
        fontsize=42, fontweight="bold",
        color="#a09888", fontfamily="serif",
        zorder=0,
    )

    # Album title — just above year in figure coords
    fig.text(
        0.97, 0.60, get_album_label(frame),
        ha="right", va="top",
        fontsize=11, fontstyle="italic",
        color="#a09888", fontfamily="serif",
        zorder=0,
    )

    # x axis label
    ax.set_xlabel("% share of top-10 word appearances per album", color="#888780",
                  fontsize=10, fontfamily="serif")

    # Per-word color legend — only show words currently visible
    legend_items = [
        plt.Rectangle((0, 0), 1, 1, fc=word_color(w))
        for w in top_words
    ]
    ax.legend(
        legend_items,
        top_words,
        loc="lower right",
        fontsize=8,
        frameon=False,
        labelcolor="#c8c0b5",
        ncol=2,
    )

    fig.patch.set_facecolor("#0e0c0a")

# -------------------------
# render
# -------------------------
print(f"Rendering {total_frames} frames at {FPS} fps...")
anim = animation.FuncAnimation(
    fig, animate,
    frames=total_frames,
    interval=1000 / FPS,
    blit=False,
    repeat=False,
