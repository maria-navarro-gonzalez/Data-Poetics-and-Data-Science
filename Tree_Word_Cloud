# -------------------------
# dominant emotion colors for trunk
# -------------------------
def get_dominant_trunk_colors(freqs, top_n=3):
    colors = []
    for word, _ in sorted(freqs.items(), key=lambda x: -x[1]):
        emotion = emotion_map.get(word, "neutral")
        color = emotion_colors[emotion]
        if color not in colors:
            colors.append(color)
        if len(colors) == top_n:
            break
    while len(colors) < 3:
        colors.append(emotion_colors["neutral"])
    return colors


# -------------------------
# word cloud plotting
# -------------------------
def make_wordcloud(freqs, title, mask, output_path=None, size=900):
    positive_freqs = {k: v for k, v in freqs.items() if v > 0}

    if not positive_freqs:
        print(f"Skipping {title}: no top words found.")
        return

    wc = WordCloud(
        width=size,
        height=size,
        background_color=None,
        mode="RGBA",
        collocations=False,
        mask=mask,
        prefer_horizontal=1.0,
        margin=4,
        random_state=42,
        color_func=emotion_color_func,
        font_path=None,
        relative_scaling=0.55,
    ).generate_from_frequencies(positive_freqs)

    wc_arr = wc.to_array().astype(float) / 255.0

    canopy_bg = build_canopy_background(size=size)

    wc_alpha = wc_arr[..., 3:4]
    composite = wc_arr * wc_alpha + canopy_bg * (1 - wc_alpha)
    composite = np.clip(composite, 0, 1)

    fig, ax = plt.subplots(figsize=(9, 11), dpi=150)
    ax.set_xlim(0, size)
    ax.set_ylim(size, 0)
    ax.axis("off")
    fig.patch.set_facecolor("white")

    ax.imshow(composite, extent=[0, size, size, 0], interpolation="bilinear")

    # trunk
    trunk_colors = get_dominant_trunk_colors(positive_freqs, top_n=3)
    scale = size / 680

    trunk_top_y  = int(490 * scale)
    trunk_bot_y  = int(730 * scale)
    trunk_top_x1 = int(310 * scale)
    trunk_top_x2 = int(370 * scale)
    trunk_bot_x1 = int(278 * scale)
    trunk_bot_x2 = int(402 * scale)

    trunk_h = trunk_bot_y - trunk_top_y
    trunk_w = trunk_bot_x2 - trunk_bot_x1
    trunk_img = build_trunk_gradient(trunk_colors, width=trunk_w, height=trunk_h)

    from matplotlib.path import Path as MplPath
    import matplotlib.patches as mp

    im = ax.imshow(
        trunk_img,
        extent=[trunk_bot_x1, trunk_bot_x2, trunk_top_y + trunk_h, trunk_top_y],
        interpolation="bilinear",
        zorder=1,
    )
    trap_verts = [
        (trunk_top_x1, trunk_top_y), (trunk_top_x2, trunk_top_y),
        (trunk_bot_x2, trunk_bot_y), (trunk_bot_x1, trunk_bot_y),
        (trunk_top_x1, trunk_top_y),
    ]
    trap_codes = [MplPath.MOVETO, MplPath.LINETO, MplPath.LINETO,
                  MplPath.LINETO, MplPath.CLOSEPOLY]
    clip_patch = mp.PathPatch(MplPath(trap_verts, trap_codes), transform=ax.transData)
    im.set_clip_path(clip_patch)

    # ground
    root_y  = int(710 * scale)
    root_cx = int(340 * scale)
    for dx, dy, length in [(-40, 14, 70), (40, 14, 70), (0, 20, 45)]:
        ax.annotate(
            "", xy=(root_cx + dx + length // 2, root_y + dy),
            xytext=(root_cx + dx, root_y),
            arrowprops=dict(arrowstyle="-", color="#8faa6e", lw=4,
                            connectionstyle="arc3,rad=0.3"),
            zorder=0,
        )
    from matplotlib.patches import Ellipse
    ground = Ellipse(
        (int(340 * scale), int(718 * scale)),
        width=int(220 * scale), height=int(30 * scale),
        color="#b8c9a8", alpha=0.45, zorder=0
    )
    ax.add_patch(ground)

    # title
    lines = title.split("\n")
    ax.set_title(
        lines[0],
        fontsize=12, fontweight="normal", color="#8a8480",
        pad=2, loc="center", fontfamily="serif",
    )
    if len(lines) > 1:
        ax.text(
            0.5, 1.038, lines[1],
            transform=ax.transAxes,
            fontsize=18, fontstyle="italic", color="#5a5853",
            ha="center", va="bottom", fontfamily="serif",
        )

    # legend
    order = ["love", "longing", "hope", "melancholy"]
    patches = [
        mpatches.Patch(color=emotion_colors[e], label=e.title())
        for e in order
    ]
    ax.legend(
        handles=patches,
        loc="lower center",
        bbox_to_anchor=(0.5, -0.04),
        ncol=len(order),
        frameon=False,
        fontsize=9,
        handlelength=1,
        handleheight=0.9,
    )

    plt.tight_layout()

    if output_path is not None:
        plt.savefig(output_path, dpi=150, bbox_inches="tight", facecolor="white")

    plt.show()
    plt.close()


