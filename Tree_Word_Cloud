# -------------------------
# create GIF
# -------------------------
images = []
for png in png_files:
    if png.exists():
        images.append(imageio.imread(png))

if images:
    from PIL import Image as PilImage
    target_size = (images[0].shape[1], images[0].shape[0])
    resized = []
    for img in images:
        if img.shape[:2] != images[0].shape[:2]:
            pil_img = PilImage.fromarray(img)
            pil_img = pil_img.resize(target_size, PilImage.LANCZOS)
            resized.append(np.array(pil_img))
        else:
            resized.append(img)
    imageio.mimsave(GIF_PATH, resized, duration=MILLISECONDS_PER_FRAME)
    print("Tree GIF created:", GIF_PATH)
else:
    print("No PNG files found, so GIF was not created.")

# -------------------------
# create grid PNG (all albums in one image)
# -------------------------
valid_pngs = [p for p in png_files if p.exists()]

if valid_pngs:
    import math
    from PIL import Image as PilImage

    imgs = [PilImage.open(p).convert("RGBA") for p in valid_pngs]
    cell_w, cell_h = imgs[0].size
    for i in range(1, len(imgs)):
        if imgs[i].size != (cell_w, cell_h):
            imgs[i] = imgs[i].resize((cell_w, cell_h), PilImage.LANCZOS)

    n = len(imgs)
    n_cols = math.ceil(math.sqrt(n))
    n_rows = math.ceil(n / n_cols)

    grid = PilImage.new("RGBA", (n_cols * cell_w, n_rows * cell_h), (255, 255, 255, 255))
    for idx, img in enumerate(imgs):
        grid.paste(img, ((idx % n_cols) * cell_w, (idx // n_cols) * cell_h))

    grid.convert("RGB").save(GRID_PATH, dpi=(150, 150))
    print("Tree grid PNG saved to:", GRID_PATH)
else:
    print("No PNG files found, so grid was not created.")
