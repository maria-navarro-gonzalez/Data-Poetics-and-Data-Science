album_years = sorted([p.name for p in root.iterdir() if p.is_dir()])

trend_rows = []
trend_rows_norm = []
png_files = []

for year in album_years:
    album_df = prepare_album(year, include_chorus=INCLUDE_CHORUS)
    album_freqs = build_freqs_title_capped(album_df, max_per_song=3)

    album_top  = filter_to_top_words(album_freqs, top_words)
    album_norm = normalize_freqs_against_full(album_freqs, full_freqs, top_words)

    trend_rows.append({"album_year": year, **album_top})
    trend_rows_norm.append({"album_year": year, **album_norm})

    png_path = PNG_DIR / f"sabina_tree_{year}.png"
    png_files.append(png_path)

    album_title = ALBUM_TITLES.get(str(year), "")
    display_title = f"Sabina — {year}\n{album_title}" if album_title else f"Sabina — {year}"
    make_wordcloud(
        freqs=album_top,
        title=display_title,
        mask=mask,
        output_path=png_path,
        size=900,
    )

