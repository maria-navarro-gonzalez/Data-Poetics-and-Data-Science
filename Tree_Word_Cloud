# -------------------------
# trunk gradient image
# -------------------------
def build_trunk_gradient(top_colors_hex, width=160, height=260):
    if len(top_colors_hex) == 1:
        top_colors_hex = top_colors_hex * 3
    elif len(top_colors_hex) == 2:
        top_colors_hex = [top_colors_hex[0], top_colors_hex[1], top_colors_hex[0]]

    c0 = mcolors.to_rgb(top_colors_hex[0])
    c1 = mcolors.to_rgb(top_colors_hex[1])
    c2 = mcolors.to_rgb(top_colors_hex[2])

    cmap = mcolors.LinearSegmentedColormap.from_list(
        "trunk", [c0, c1, c1, c2], N=256
    )

    gradient = np.linspace(0, 1, width)
    trunk_rgb = cmap(gradient)[np.newaxis, :, :3]
    trunk_rgb = np.repeat(trunk_rgb, height, axis=0)

    dark_factor = np.linspace(1.0, 0.78, height)[:, np.newaxis, np.newaxis]
    trunk_rgb = trunk_rgb * dark_factor

    alpha = np.ones((height, width, 1))
    trunk_rgba = np.concatenate([trunk_rgb, alpha], axis=2)
    return trunk_rgba


