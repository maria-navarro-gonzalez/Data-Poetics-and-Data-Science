# -------------------------
# load lyrics corpus
# -------------------------
def load_lyrics_corpus(base_dir, artist, album_year=None):
    root = Path(base_dir) / artist
    if album_year is not None:
        root = root / str(album_year)
    if not root.exists():
        raise FileNotFoundError(f"Folder not found: {root}")
    rows = []
    for p in root.rglob("*.txt"):
        text = p.read_text(encoding="utf-8", errors="replace")
        filename = p.name
        album = p.parent.name
        m = re.match(r"^(\d+)_", filename)
        track = int(m.group(1)) if m else None
        song = re.sub(r"^\d+_", "", filename).replace(".txt", "").replace("_", " ")
        rows.append({
            "artist": artist, "album_year": album, "track": track,
            "song": song, "filename": filename, "text_raw": text
        })
    if not rows:
        raise ValueError(f"No .txt files found in {root}")
    df = pd.DataFrame(rows)
    df = df.sort_values(["album_year", "track"]).reset_index(drop=True)
    return df

# -------------------------
# cleaning helpers
# -------------------------
def remove_song_headers(text):
    text = re.sub(r"^\s*\[.*?\]\s*$", "", text, flags=re.MULTILINE)
    return re.sub(r"\n{2,}", "\n", text).strip()

def normalize_text(text):
    # keeps standard latin + accented characters — adjust regex for other scripts
    text = text.lower()
    text = re.sub(r"[^a-záéíóúüñàèìòùâêîôûëïüç\s]", " ", text)
    return re.sub(r"\s+", " ", text).strip()

def tokenize_and_remove_stopwords(text, min_len=2):
    return [t for t in text.split() if t not in all_stopwords and len(t) >= min_len]

def _is_low_information_line(line):
    norm = re.sub(r"\s+", " ", re.sub(r"[^a-z\s]", "", line.strip().lower())).strip()
    if not norm:
        return False
    tokens = norm.split()
    if not tokens:
        return False
    if len([t for t in tokens if len(t) <= 3]) / len(tokens) >= 0.8:
        return True
    if Counter(tokens).most_common(1)[0][1] / len(tokens) >= 0.8:
        return True
    if re.search(r"(.)\1{4,}", norm):
        return True
    chars = [c for c in norm if c != " "]
    if len(chars) >= 6 and len(set(chars)) <= 4:
        return True
    return False

def remove_low_information_lines(text):
    out = "\n".join(l for l in text.splitlines() if not _is_low_information_line(l))
    return re.sub(r"\n{2,}", "\n", out).strip()

def normalize_line_soft(line):
    return re.sub(r"\s+", " ", re.sub(r"[^\w\s]", "", line.strip().lower())).strip()

def get_nonempty_lines(text):
    return [l.strip() for l in text.splitlines() if l.strip()]

def find_repeated_lines(text, min_line_len=12, min_repeats=2, min_gap=2):
    norm_lines = [normalize_line_soft(l) for l in get_nonempty_lines(text)]
    positions = defaultdict(list)
    for i, norm in enumerate(norm_lines):
        if len(norm) >= min_line_len:
            positions[norm].append(i)
    return {norm for norm, idxs in positions.items()
            if len(idxs) >= min_repeats and
            any(idxs[j+1] - idxs[j] >= min_gap for j in range(len(idxs)-1))}

def find_repeated_blocks(text, block_size=2, min_repeats=2, min_line_len=8):
    norm_lines = [normalize_line_soft(l) for l in get_nonempty_lines(text)]
    blocks = [tuple(norm_lines[i:i+block_size])
              for i in range(len(norm_lines) - block_size + 1)
              if all(len(l) >= min_line_len for l in norm_lines[i:i+block_size])]
    counts = Counter(blocks)
    return {b for b, c in counts.items() if c >= min_repeats}

def remove_chorus_lines_and_blocks(text):
    lines = get_nonempty_lines(text)
    norm_lines = [normalize_line_soft(l) for l in lines]
    repeated_lines   = find_repeated_lines(text)
    repeated_2blocks = find_repeated_blocks(text, block_size=2)
    repeated_3blocks = find_repeated_blocks(text, block_size=3)
    keep = [True] * len(lines)
    for i, norm in enumerate(norm_lines):
        if norm in repeated_lines:
            keep[i] = False
    for i in range(len(norm_lines) - 1):
        if tuple(norm_lines[i:i+2]) in repeated_2blocks:
            keep[i] = keep[i+1] = False
    for i in range(len(norm_lines) - 2):
        if tuple(norm_lines[i:i+3]) in repeated_3blocks:
            keep[i] = keep[i+1] = keep[i+2] = False
    return "\n".join(l for i, l in enumerate(lines) if keep[i])

# -------------------------
# cached preparation
# -------------------------
_prepared_cache = {}

def prepare_full_corpus(include_chorus=True):
    key = f"full_{include_chorus}"
    if key in _prepared_cache:
        return _prepared_cache[key]
    df = load_lyrics_corpus(BASE_DIR, ARTIST)
    df["text_raw"] = df["text_raw"].apply(remove_song_headers).apply(remove_low_information_lines)
    if not include_chorus:
        df["text_raw"] = df["text_raw"].apply(remove_chorus_lines_and_blocks)
    df["text_clean"] = df["text_raw"].apply(normalize_text)
    df["tokens"] = df["text_clean"].apply(tokenize_and_remove_stopwords)
    df["song_key"] = df["song"].apply(normalize_text)
    _prepared_cache[key] = df
    return df

def prepare_album(year, include_chorus=True):
    key = f"{year}_{include_chorus}"
    if key in _prepared_cache:
        return _prepared_cache[key]
    df = load_lyrics_corpus(BASE_DIR, ARTIST, album_year=year)
    df["text_raw"] = df["text_raw"].apply(remove_song_headers).apply(remove_low_information_lines)
    if not include_chorus:
        df["text_raw"] = df["text_raw"].apply(remove_chorus_lines_and_blocks)
    df["text_clean"] = df["text_raw"].apply(normalize_text)
    df["tokens"] = df["text_clean"].apply(tokenize_and_remove_stopwords)
    _prepared_cache[key] = df
    return df

# -------------------------
# frequency building
# -------------------------
def build_freqs_title_capped(df, max_per_song=3):
    freqs = Counter()
    for _, row in df.iterrows():
        token_counts = Counter(row["tokens"])
        for word, count in token_counts.items():
            freqs[word] += min(count, max_per_song)
        for tw in set(normalize_text(row["song"]).split()):
            if token_counts.get(tw, 0) > 1:
                freqs[tw] -= (min(token_counts[tw], max_per_song) - 1)
    return freqs

def filter_to_top_words(freqs, top_words):
    return {w: freqs.get(w, 0) for w in top_words}

# -------------------------
# color helpers
# -------------------------
def emotion_color_func(word, font_size, position, orientation, random_state=None, **kwargs):
    emotion = EMOTION_MAP.get(word, "neutral")
    return EMOTION_COLORS.get(emotion, "#4a4845")

def get_dominant_colors(freqs, top_n=3):
    colors = []
    for word, _ in sorted(freqs.items(), key=lambda x: -x[1]):
        color = EMOTION_COLORS.get(EMOTION_MAP.get(word, "neutral"), "#4a4845")
        if color not in colors:
            colors.append(color)
        if len(colors) == top_n:
            break
    while len(colors) < 3:
        colors.append(EMOTION_COLORS.get("neutral", "#4a4845"))
    return colors

