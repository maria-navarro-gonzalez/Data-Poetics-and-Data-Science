# -------------------------
# trunk gradient
# -------------------------
def build_trunk_gradient(colors_hex, width=160, height=260):
    if len(colors_hex) == 1: colors_hex = colors_hex * 3
    elif len(colors_hex) == 2: colors_hex = [colors_hex[0], colors_hex[1], colors_hex[0]]
    c0, c1, c2 = [mcolors.to_rgb(c) for c in colors_hex[:3]]
    cmap = mcolors.LinearSegmentedColormap.from_list("trunk", [c0,c1,c1,c2], N=256)
    gradient = np.linspace(0, 1, width)
    rgb = np.repeat(cmap(gradient)[np.newaxis,:,:3], height, axis=0)
    rgb *= np.linspace(1.0, 0.78, height)[:,np.newaxis,np.newaxis]
    return np.concatenate([rgb, np.ones((height,width,1))], axis=2)

# -------------------------
# sales to size
# -------------------------
def sales_to_size(year):
    if not ALBUM_SALES:
        return (MIN_SIZE + MAX_SIZE) // 2   # fixed size if no sales data provided
    sales = ALBUM_SALES.get(str(year), min(ALBUM_SALES.values()))
    s_min, s_max = min(ALBUM_SALES.values()), max(ALBUM_SALES.values())
    if s_min == s_max:
        return (MIN_SIZE + MAX_SIZE) // 2
    t = (sales - s_min) / (s_max - s_min)
    return int(MIN_SIZE + t * (MAX_SIZE - MIN_SIZE))

# -------------------------
# word cloud plotting
# -------------------------
def make_wordcloud(freqs, title, mask, output_path=None, size=900):
    from PIL import Image as PilImage
    positive_freqs = {k: v for k, v in freqs.items() if v > 0}
    if not positive_freqs:
        print(f"Skipping {title}: no words found.")
        return

    CANVAS = int(size * 1.15)   # canvas slightly larger than hat to avoid clipping

    # Render word cloud at 4x for sharpness
    render_size = size * 4
    if SHAPE == "hat":
        mask_hires = create_hat_mask(size=render_size)
    else:
        mask_hires = create_tree_mask(size=render_size)

    wc = WordCloud(
        width=render_size, height=render_size,
        background_color=None, mode="RGBA",
        collocations=False, mask=mask_hires,
        prefer_horizontal=1.0, margin=8,
        random_state=42, color_func=emotion_color_func,
        relative_scaling=0.55,
    ).generate_from_frequencies(positive_freqs)

    wc_pil = PilImage.fromarray(wc.to_array())
    wc_pil = wc_pil.resize((size, size), PilImage.LANCZOS)
    wc_arr = np.array(wc_pil).astype(float) / 255.0

    # Background
    if SHAPE == "hat":
        bg_hires = build_hat_background(size=size*4)
    else:
        bg_hires = build_canopy_background(size=size*4)
    bg_pil = PilImage.fromarray((bg_hires*255).astype(np.uint8))
    bg_pil = bg_pil.resize((size, size), PilImage.LANCZOS)
    bg = np.array(bg_pil).astype(float) / 255.0

    # Composite
    alpha = wc_arr[..., 3:4]
    composite = np.clip(wc_arr*alpha + bg*(1-alpha), 0, 1)

    # Place on fixed canvas
    canvas_img = PilImage.new("RGBA", (CANVAS, CANVAS), (255,255,255,255))
    hat_img = PilImage.fromarray((composite*255).astype(np.uint8))
    offset = (CANVAS - size) // 2
    canvas_img.paste(hat_img, (offset, offset), hat_img)

    # Figure
    fig, ax = plt.subplots(figsize=(9,9), dpi=150)
    ax.set_xlim(0, CANVAS)
    ax.set_ylim(CANVAS, 0)
    ax.axis("off")
    fig.patch.set_facecolor("white")

    ax.imshow(np.array(canvas_img), extent=[0,CANVAS,CANVAS,0],
              interpolation="bilinear", zorder=1)

    # Emotion gradient shadow
    dominant_colors = get_dominant_colors(positive_freqs, top_n=3)
    scale = size / 680
    shadow_cx = offset + int(340*scale)
    shadow_cy = offset + int(430*scale)
    shadow_rx = int(200*scale)
    shadow_ry = int(10*scale)
    c0,c1,c2 = [mcolors.to_rgb(c) for c in dominant_colors]
    grad_cmap = mcolors.LinearSegmentedColormap.from_list("shadow",[c0,c1,c1,c2,c0],N=512)
    grad_img = ax.imshow(
        np.linspace(0,1,512).reshape(1,-1), cmap=grad_cmap, aspect="auto",
        extent=[shadow_cx-shadow_rx, shadow_cx+shadow_rx,
                shadow_cy+shadow_ry, shadow_cy-shadow_ry],
        alpha=0.55, zorder=2, interpolation="bilinear",
    )
    from matplotlib.patches import Ellipse as MplEllipse
    grad_img.set_clip_path(MplEllipse(
        (shadow_cx, shadow_cy), width=shadow_rx*2, height=shadow_ry*2,
        transform=ax.transData,
    ))

    # Trunk (tree shape only)
    if SHAPE == "tree":
        trunk_colors = get_dominant_colors(positive_freqs, top_n=3)
        trunk_top_y  = offset + int(490*scale)
        trunk_bot_y  = offset + int(730*scale)
        trunk_top_x1 = offset + int(310*scale)
        trunk_top_x2 = offset + int(370*scale)
        trunk_bot_x1 = offset + int(278*scale)
        trunk_bot_x2 = offset + int(402*scale)
        trunk_h = trunk_bot_y - trunk_top_y
        trunk_w = trunk_bot_x2 - trunk_bot_x1
        trunk_img = build_trunk_gradient(trunk_colors, width=trunk_w, height=trunk_h)
        from matplotlib.path import Path as MplPath
        import matplotlib.patches as mp
        im = ax.imshow(trunk_img,
            extent=[trunk_bot_x1,trunk_bot_x2,trunk_top_y+trunk_h,trunk_top_y],
            interpolation="bilinear", zorder=1)
        trap = MplPath(
            [(trunk_top_x1,trunk_top_y),(trunk_top_x2,trunk_top_y),
             (trunk_bot_x2,trunk_bot_y),(trunk_bot_x1,trunk_bot_y),
