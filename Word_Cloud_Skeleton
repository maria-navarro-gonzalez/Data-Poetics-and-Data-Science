# create grid PNG
valid = [p for p in png_files if p.exists()]
if valid:
    from PIL import Image as PilImage
    imgs = [PilImage.open(p).convert("RGBA") for p in valid]
    cell_w, cell_h = imgs[0].size
    for i in range(1, len(imgs)):
        if imgs[i].size != (cell_w, cell_h):
            imgs[i] = imgs[i].resize((cell_w, cell_h), PilImage.LANCZOS)
    n_cols = math.ceil(math.sqrt(len(imgs)))
    n_rows = math.ceil(len(imgs) / n_cols)
    grid = PilImage.new("RGBA", (n_cols*cell_w, n_rows*cell_h), (255,255,255,255))
    for idx, img in enumerate(imgs):
        grid.paste(img, ((idx%n_cols)*cell_w, (idx//n_cols)*cell_h))
    grid.convert("RGB").save(GRID_PATH, dpi=(150,150))
    print("Grid PNG saved to:", GRID_PATH)
