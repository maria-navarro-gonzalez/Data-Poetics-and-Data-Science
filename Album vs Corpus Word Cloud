def remove_song_headers(text):
    # removes bracketed section headers on their own lines (ex: [CHORUS])
    text = re.sub(r"^\s*\[.*?\]\s*$", "", text, flags=re.MULTILINE)

    # collapses multiple blank lines into one line break
    text = re.sub(r"\n{2,}", "\n", text).strip()

    return text

def normalize_text(text):
    # makes everything lowercase
    text = text.lower()

    # keeps only Spanish letters and spaces
    text = re.sub(r"[^a-záéíóúüñ\s]", " ", text)

    # collapses multiple spaces into one
    text = re.sub(r"\s+", " ", text).strip()

    return text

def tokenize_and_remove_stopwords(text, min_len=2):
    # splits into tokens by spaces
    tokens = text.split()

    # removes stopwords and very short tokens
    tokens = [
        t for t in tokens
        if t not in all_stopwords and len(t) >= min_len
    ]

    return tokens

def _normalize_line_for_match(line):
    # normalizes a line so chant patterns are easier to detect
    line = line.strip().lower()

    # keeps only Spanish letters and spaces
    line = re.sub(r"[^a-záéíóúüñ\s]", "", line)

    # collapses multiple spaces into one
    line = re.sub(r"\s+", " ", line).strip()

    return line

def _is_low_information_line(line):
    #detects chant-like filler lines such as, ta ta ta, ta ta taaaaa, tatata ta ta, uoh uoh uoh#

    norm = _normalize_line_for_match(line)

    if not norm:
        return False

    tokens = norm.split()
    if not tokens:
        return False

    # very short tokens only (ta, la, na, oh, uoh, etc.)
    short_tokens = [t for t in tokens if len(t) <= 3]
    short_ratio = len(short_tokens) / len(tokens)

    # mostly short tokens
    if short_ratio >= 0.8:
        return True

    # dominated by one token
    counts = Counter(tokens)
    most_common = counts.most_common(1)[0][1]
    if most_common / len(tokens) >= 0.8:
        return True

    # long character repetition (taaaaa, ooooo)
    if re.search(r"(.)\1{4,}", norm):
        return True

    # very low character diversity
    chars = [c for c in norm if c != " "]
    if len(chars) >= 6 and len(set(chars)) <= 4:
        return True

    return False

def remove_low_information_lines(text):
    lines = text.splitlines()
    cleaned = []

    for line in lines:
        if not _is_low_information_line(line):
            cleaned.append(line)

    out = "\n".join(cleaned)
    out = re.sub(r"\n{2,}", "\n", out).strip()
    return out

def normalize_line_soft(line):
    # normalizes a line for chorus matching while preserving line structures#
    line = line.strip().lower()
    line = re.sub(r"[^\wáéíóúüñ\s]", "", line)
    line = re.sub(r"\s+", " ", line).strip()
    return line

def get_nonempty_lines(text):
    return [line.strip() for line in text.splitlines() if line.strip()]

def find_repeated_lines(text, min_line_len=12, min_repeats=2, min_gap=2):
    # finds repeated lyric lines likely to function as chorus/refrain lines#
    lines = get_nonempty_lines(text)
    norm_lines = [normalize_line_soft(line) for line in lines]

    positions = defaultdict(list)

    for i, norm in enumerate(norm_lines):
        if len(norm) >= min_line_len:
            positions[norm].append(i)

    chorus_lines = set()

    for norm, idxs in positions.items():
        if len(idxs) >= min_repeats:
            gaps = [idxs[j + 1] - idxs[j] for j in range(len(idxs) - 1)]
            if any(gap >= min_gap for gap in gaps):
                chorus_lines.add(norm)

    return chorus_lines

def find_repeated_blocks(text, block_size=2, min_repeats=2, min_line_len=8):
    # finds repeated 2-line or 3-line blocks, which often signal chorus/refrain#
    lines = get_nonempty_lines(text)
    norm_lines = [normalize_line_soft(line) for line in lines]

    blocks = []
    for i in range(len(norm_lines) - block_size + 1):
        block = tuple(norm_lines[i:i + block_size])
        if all(len(line) >= min_line_len for line in block):
            blocks.append((i, block))

    counts = Counter(block for _, block in blocks)
    repeated_blocks = {block for block, c in counts.items() if c >= min_repeats}

    return repeated_blocks

def remove_chorus_lines_and_blocks(text, remove_blocks=True):
    # removes likely chorus material based on repeated lines and repeated blocks#
    lines = get_nonempty_lines(text)
    norm_lines = [normalize_line_soft(line) for line in lines]

    repeated_lines = find_repeated_lines(text)
    repeated_2blocks = find_repeated_blocks(text, block_size=2) if remove_blocks else set()
    repeated_3blocks = find_repeated_blocks(text, block_size=3) if remove_blocks else set()

    keep = [True] * len(lines)

    # mark repeated single lines
    for i, norm in enumerate(norm_lines):
        if norm in repeated_lines:
            keep[i] = False

    # mark repeated 2-line blocks
    for i in range(len(norm_lines) - 1):
        block2 = tuple(norm_lines[i:i + 2])
        if block2 in repeated_2blocks:
            keep[i] = False
            keep[i + 1] = False

    # mark repeated 3-line blocks
    for i in range(len(norm_lines) - 2):
        block3 = tuple(norm_lines[i:i + 3])
        if block3 in repeated_3blocks:
            keep[i] = False
            keep[i + 1] = False
            keep[i + 2] = False

    cleaned_lines = [line for i, line in enumerate(lines) if keep[i]]
    return "\n".join(cleaned_lines)

_prepared_cache = {}

def prepare_full_corpus(include_chorus=True):
    # loads and prepares the full discography
    key = f"full_{include_chorus}"
    if key in _prepared_cache:
        return _prepared_cache[key]

    df = load_lyrics_corpus(BASE_DIR, ARTIST, album_year=None)

    df["text_raw"] = df["text_raw"].apply(remove_song_headers)
    df["text_raw"] = df["text_raw"].apply(remove_low_information_lines)

    if not include_chorus:
        df["text_raw"] = df["text_raw"].apply(remove_chorus_lines_and_blocks)

    df["text_clean"] = df["text_raw"].apply(normalize_text)
    df["tokens"] = df["text_clean"].apply(tokenize_and_remove_stopwords)

    # matches duplicate titles across albums
    df["song_key"] = df["song"].apply(normalize_text)

    _prepared_cache[key] = df
    return df

def prepare_album(year, include_chorus=True):
    # loads and prepares a specific album (year required)
    if year is None:
        raise ValueError("Input year at the top of the notebook (ALBUM_YEAR = ____).")

    key = f"{year}_{include_chorus}"
    if key in _prepared_cache:
        return _prepared_cache[key]

    df = load_lyrics_corpus(BASE_DIR, ARTIST, album_year=year)

    df["text_raw"] = df["text_raw"].apply(remove_song_headers)
    df["text_raw"] = df["text_raw"].apply(remove_low_information_lines)

    if not include_chorus:
        df["text_raw"] = df["text_raw"].apply(remove_chorus_lines_and_blocks)

    df["text_clean"] = df["text_raw"].apply(normalize_text)
    df["tokens"] = df["text_clean"].apply(tokenize_and_remove_stopwords)

    _prepared_cache[key] = df
    return df

def build_freqs_title_capped(df, max_per_song=3):
    # builds word frequencies but caps how many times a word can count per song #
    # also caps title words to 1 per song #

    freqs = Counter()

    for _, row in df.iterrows():
        tokens = row["tokens"]
        token_counts = Counter(tokens)

        # cap every word per song
        for word, count in token_counts.items():
            freqs[word] += min(count, max_per_song)

        # cap title words to 1
        title_words = set(normalize_text(row["song"]).split())
        for tw in title_words:
            if token_counts.get(tw, 0) > 1:
                freqs[tw] -= (min(token_counts[tw], max_per_song) - 1)

    return freqs

def plot_wordcloud_from_freqs(freqs, title):
    wc = WordCloud(
        width=800,
        height=400,
        background_color="white",
        collocations=False
    )
    wc.generate_from_frequencies(freqs)

    plt.figure(figsize=(12, 6))
    plt.imshow(wc, interpolation="bilinear")
    plt.axis("off")
    plt.title(title)
    plt.show()

