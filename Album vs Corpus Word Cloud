def count_song_versions(df, song_title):
    # normalizes the input title (lowercase, remove punctuation, etc.)
    song_key = normalize_text(song_title)

    # compares each song_key in the dataframe to the normalized input
    count = (df["song_key"] == song_key).sum()

    print(f"'{song_title}' appears {count} time(s) in the dataset.")
    return count

