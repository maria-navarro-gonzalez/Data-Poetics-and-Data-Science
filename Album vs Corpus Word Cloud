def load_lyrics_corpus(base_dir, artist, album_year=None):
    # base folder path: .../lyrics_txt/sabina/
    root = Path(base_dir) / artist

    # if album_year is given: .../lyrics_txt/sabina/2017/
    if album_year is not None:
        root = root / str(album_year)

    if not root.exists():
        raise FileNotFoundError(f"Folder not found: {root}")

    rows = []

    # finds all .txt lyric files recursively
    for p in root.rglob("*.txt"):
        # reads the file text
        text = p.read_text(encoding="utf-8", errors="replace")

        filename = p.name
        album = p.parent.name

        # extracts track number at start of filename (ex: 08_)
        m = re.match(r"^(\d+)_", filename)
        track = int(m.group(1)) if m else None

        # cleans the song title from filename
        song = (
            re.sub(r"^\d+_", "", filename)
            .replace(".txt", "")
            .replace("_", " ")
        )

        rows.append({
            "artist": artist,
            "album_year": album,
            "track": track,
            "song": song,
            "filename": filename,
            "text_raw": text
        })

    if not rows:
        raise ValueError(f"No .txt files found in {root}")

    df = pd.DataFrame(rows)

    # sorts songs by album year and track number
    df = df.sort_values(["album_year", "track"]).reset_index(drop=True)

    return df

