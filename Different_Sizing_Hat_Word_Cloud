# Hat size range: smallest album → MIN_SIZE, largest → MAX_SIZE
MIN_SIZE = 1800
MAX_SIZE = 2800

def sales_to_size(year):
    """Scale hat size linearly between MIN_SIZE and MAX_SIZE based on sales."""
    sales = ALBUM_SALES.get(str(year), 300)
    all_sales = list(ALBUM_SALES.values())
    min_s, max_s = min(all_sales), max(all_sales)
    t = (sales - min_s) / (max_s - min_s)
    return int(MIN_SIZE + t * (MAX_SIZE - MIN_SIZE))

