# -------------------------
# create grid PNG (all albums in one image)
# -------------------------
valid_pngs = [p for p in png_files if p.exists()]

if valid_pngs:
    from PIL import Image as PilImage
    import math

    # Load all individual PNGs
    imgs = [PilImage.open(p).convert("RGBA") for p in valid_pngs]

    # Standardise size to first image
    cell_w, cell_h = imgs[0].size
    for i in range(1, len(imgs)):
        if imgs[i].size != (cell_w, cell_h):
            imgs[i] = imgs[i].resize((cell_w, cell_h), PilImage.LANCZOS)

    # Grid layout: aim for roughly square grid
    n = len(imgs)
    n_cols = math.ceil(math.sqrt(n))
    n_rows = math.ceil(n / n_cols)

    grid_w = n_cols * cell_w
    grid_h = n_rows * cell_h

    grid = PilImage.new("RGBA", (grid_w, grid_h), (255, 255, 255, 255))

    for idx, img in enumerate(imgs):
        row = idx // n_cols
        col = idx % n_cols
        grid.paste(img, (col * cell_w, row * cell_h))

    # Convert to RGB for saving as PNG (removes alpha)
    grid_rgb = grid.convert("RGB")
    GRID_PATH = OUTPUT_DIR / "sabina_all_albums_grid.png"
    grid_rgb.save(GRID_PATH, dpi=(150, 150))
    print("Grid PNG saved to:", GRID_PATH)
else:
    print("No PNG files found, so grid was not created.")
