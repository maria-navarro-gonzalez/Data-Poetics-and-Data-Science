def compute_pct_freqs(album_top, top_n_words):
    """
    Returns a dict of word -> percentage share of total count
    across the top N words for this album.
    e.g. if 'vida' appears 6 times and total top-10 count is 40,
    vida's share = 6/40 * 100 = 15.0%
    """
    counts = {w: album_top.get(w, 0) for w in top_n_words}
    total = sum(counts.values())
    if total == 0:
        return {w: 0.0 for w in top_n_words}
    return {w: round(v / total * 100, 2) for w, v in counts.items()}

