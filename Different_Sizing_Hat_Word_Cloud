# -------------------------
# emotion gradient shadow
# -------------------------
def build_emotion_shadow(dominant_colors, size=900):
    """
    Returns an RGBA numpy array with a horizontal gradient ellipse
    at the base of the hat, using the dominant emotion colors.
    """
    from PIL import Image, ImageDraw

    img = Image.new("RGBA", (size, size), (0, 0, 0, 0))

    # Build gradient strip
    w = int(400 * size / 680)
    h = int(20 * size / 680)
    cx = size // 2
    cy = int(430 * size / 680)

    c0 = tuple(int(dominant_colors[0].lstrip("#")[i:i+2], 16) for i in (0,2,4))
    c1 = tuple(int(dominant_colors[1].lstrip("#")[i:i+2], 16) for i in (0,2,4))
    c2 = tuple(int(dominant_colors[2].lstrip("#")[i:i+2], 16) for i in (0,2,4))

    strip = Image.new("RGBA", (w, h), (0, 0, 0, 0))
    s_draw = ImageDraw.Draw(strip)
    for x in range(w):
        t = x / (w - 1)
        if t < 0.35:
            r = int(c0[0] + (c1[0]-c0[0]) * t/0.35)
            g = int(c0[1] + (c1[1]-c0[1]) * t/0.35)
            b = int(c0[2] + (c1[2]-c0[2]) * t/0.35)
        elif t < 0.65:
            r, g, b = c1
        elif t < 0.85:
            tt = (t-0.65)/0.20
            r = int(c1[0] + (c2[0]-c1[0]) * tt)
            g = int(c1[1] + (c2[1]-c1[1]) * tt)
            b = int(c1[2] + (c2[2]-c1[2]) * tt)
        else:
            tt = (t-0.85)/0.15
            r = int(c2[0] + (c0[0]-c2[0]) * tt)
            g = int(c2[1] + (c0[1]-c2[1]) * tt)
            b = int(c2[2] + (c0[2]-c2[2]) * tt)
        alpha = int(140 * (1 - abs(2*t - 1)))  # fade at edges
        s_draw.line([(x, 0), (x, h-1)], fill=(r, g, b, alpha))

    # Paste as ellipse using strip as base
    mask_ellipse = Image.new("L", (w, h), 0)
    me_draw = ImageDraw.Draw(mask_ellipse)
    me_draw.ellipse([0, 0, w-1, h-1], fill=255)
    strip.putalpha(mask_ellipse)

    img.paste(strip, (cx - w//2, cy - h//2), strip)
    return np.array(img).astype(float) / 255.0


# -------------------------
# dominant emotion colors for trunk
# -------------------------
def get_dominant_trunk_colors(freqs, top_n=3):
    """
    Returns the hex colors of the top_n most frequent words,
    in frequency order, for use in the trunk gradient.
    Falls back to hope green if unmapped.
    """
    colors = []
    for word, _ in sorted(freqs.items(), key=lambda x: -x[1]):
        emotion = emotion_map.get(word, "neutral")
        color = emotion_colors[emotion]
        if color not in colors:
            colors.append(color)
        if len(colors) == top_n:
            break
    while len(colors) < 3:
        colors.append(emotion_colors["neutral"])
    return colors


# -------------------------
# word cloud plotting
# -------------------------
def make_wordcloud(freqs, title, mask, output_path=None, size=900):
    from PIL import Image as PilImage
    positive_freqs = {k: v for k, v in freqs.items() if v > 0}

    if not positive_freqs:
        print(f"Skipping {title}: no top words found.")
        return

    # CANVAS_SIZE: fixed output resolution for every album so GIF frames
    # are all the same pixel dimensions regardless of hat size.
    # 'size' controls how large the hat is drawn within the canvas.
    CANVAS = 3000

    # --- word cloud: always render at 4x hat size for sharpness ---
    render_size = size * 4
    mask_hires = create_hat_mask(size=render_size)
    wc = WordCloud(
        width=render_size,
        height=render_size,
        background_color=None,
        mode="RGBA",
        collocations=False,
        mask=mask_hires,
        prefer_horizontal=1.0,
        margin=8,
        random_state=42,
        color_func=emotion_color_func,
        font_path=None,
        relative_scaling=0.55,
    ).generate_from_frequencies(positive_freqs)

    # Downsample to hat size with LANCZOS antialiasing
    wc_pil = PilImage.fromarray(wc.to_array())
    wc_pil = wc_pil.resize((size, size), PilImage.LANCZOS)
    wc_arr = np.array(wc_pil).astype(float) / 255.0

    # --- hat background at 4x, downsampled ---
    hat_bg_hires = build_hat_background(size=size * 4)
    hat_bg_pil = PilImage.fromarray((hat_bg_hires * 255).astype(np.uint8))
    hat_bg_pil = hat_bg_pil.resize((size, size), PilImage.LANCZOS)
    hat_bg = np.array(hat_bg_pil).astype(float) / 255.0

    # Composite hat + words
    wc_alpha = wc_arr[..., 3:4]
    composite = np.clip(wc_arr * wc_alpha + hat_bg * (1 - wc_alpha), 0, 1)

    # Place composite centred on a fixed white canvas
    canvas_img = PilImage.new("RGBA", (CANVAS, CANVAS), (255, 255, 255, 255))
    hat_img = PilImage.fromarray((composite * 255).astype(np.uint8))
    offset = (CANVAS - size) // 2
    canvas_img.paste(hat_img, (offset, offset), hat_img)

    # --- figure: always the same physical size & DPI ---
    fig, ax = plt.subplots(figsize=(9, 9), dpi=150)
    ax.set_xlim(0, CANVAS)
    ax.set_ylim(CANVAS, 0)
    ax.axis("off")
    fig.patch.set_facecolor("white")

    # Draw the composited canvas
    ax.imshow(np.array(canvas_img), extent=[0, CANVAS, CANVAS, 0],
              interpolation="bilinear", zorder=1)

    # --- emotion gradient shadow — coordinates adjusted for canvas offset ---
    dominant_colors = get_dominant_trunk_colors(positive_freqs, top_n=3)
    scale = size / 680
    shadow_cx = offset + int(340 * scale)
    shadow_cy = offset + int(430 * scale)
    shadow_rx = int(200 * scale)
    shadow_ry = int(10  * scale)

    # Build gradient as a horizontal imshow strip, clipped to an Ellipse patch
    c0 = mcolors.to_rgb(dominant_colors[0])
    c1 = mcolors.to_rgb(dominant_colors[1])
    c2 = mcolors.to_rgb(dominant_colors[2])
    grad_cmap = mcolors.LinearSegmentedColormap.from_list(
        "shadow", [c0, c1, c1, c2, c0], N=512
    )
    grad_data = np.linspace(0, 1, 512).reshape(1, -1)
    grad_img = ax.imshow(
        grad_data,
        cmap=grad_cmap,
        aspect="auto",
        extent=[shadow_cx - shadow_rx, shadow_cx + shadow_rx,
                shadow_cy + shadow_ry, shadow_cy - shadow_ry],
        alpha=0.55,
        zorder=2,
        interpolation="bilinear",
    )
    from matplotlib.patches import Ellipse as MplEllipse
    clip_ellipse = MplEllipse(
        (shadow_cx, shadow_cy),
        width=shadow_rx * 2, height=shadow_ry * 2,
        transform=ax.transData,
    )
    grad_img.set_clip_path(clip_ellipse)

    # (hat + words already drawn on canvas above)

    # --- title: album name large on top, year smaller below ---
    lines = title.split("\n")
    ax.set_title(
        lines[0],
        fontsize=12, fontweight="normal", color="#8a8480",
        pad=2, loc="center", fontfamily="serif",
    )
    if len(lines) > 1:
